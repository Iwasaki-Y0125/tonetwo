<main class="tt-page-main">
  <section class="tt-page-section-form">
    <h1 class="tt-page-heading-form-sub">投稿作成</h1>

    <% if flash[:alert] %>
      <div class="alert alert-error mb-6">
        <span><%= flash[:alert] %></span>
      </div>
    <% end %>

    <%= form_with model: @post,
                  url: posts_path,
                  class: "tt-post-form-card space-y-5",
                  data: {
                    controller: "post-body-length auto-grow-textarea",
                    post_body_length_limit_value: 140,
                    action: "submit->post-body-length#guardSubmit"
                  } do |form| %>
      <div class="alert alert-error mb-6 hidden" data-post-body-length-target="alert">
        <span>140字を超えているため投稿できません</span>
      </div>

      <fieldset class="fieldset">
        <legend class="fieldset-legend text-base font-semibold">本文</legend>
        <%= form.text_area :body,
                           required: true,
                           rows: 5,
                           class: "textarea textarea-plain w-full resize-none overflow-hidden bg-white",
                           placeholder: "今どんな感じ？(140字まで)",
                           data: {
                             post_body_length_target: "input",
                             auto_grow_textarea_target: "field",
                             action: "input->post-body-length#check input->auto-grow-textarea#resize"
                           } %>
        <p class="text-sm mt-2 min-h-6 text-error invisible" data-post-body-length-target="message" aria-live="polite"></p>
      </fieldset>

      <div>
        <%= form.submit "投稿する", class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </section>
</main>
