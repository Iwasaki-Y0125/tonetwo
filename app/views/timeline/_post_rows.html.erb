<%# 投稿を表示する本体 %>
<% posts.each do |post| %>
  <%# 表示はJST基準。今日の投稿だけ時刻のみを出す。 %>
  <% posted_at = post.created_at.in_time_zone("Asia/Tokyo") %>
  <% posted_at_label = posted_at.today? ? posted_at.strftime("%H:%M Today") : posted_at.strftime("%Y/%m/%d %H:%M") %>

  <%# 自分の投稿だけ詳細ページへ遷移できるようにする。 %>
  <% if post.user_id == Current.user.id %>
    <%= link_to my_post_path(post),
                class: "tt-post-row tt-post-row-no-icon tt-post-row-link group",
                data: { turbo_frame: "_top" },
                aria: { label: "自分の投稿詳細へ" } do %>
      <div class="tt-post-content">
        <div class="tt-post-row-head">
          <p class="tt-self-post-badge">自分の投稿</p>
          <p class="tt-post-meta tt-post-meta-no-icon"><%= posted_at_label %></p>
        </div>
        <p class="tt-post-body"><%= post.body.to_s.strip %></p>
      </div>
    <% end %>
  <% else %>
    <%# 他ユーザー投稿はクリックでチャット下書き画面へ遷移する。 %>
    <%= link_to new_post_chat_path(post),
                class: "tt-post-row tt-post-row-no-icon tt-post-row-link group",
                data: { turbo_frame: "_top" },
                aria: { label: "チャット詳細へ" } do %>
      <div class="tt-post-content">
        <p class="tt-post-meta tt-post-meta-no-icon"><%= posted_at_label %></p>
        <p class="tt-post-body"><%= post.body.to_s.strip %></p>
      </div>
    <% end %>
  <% end %>
<% end %>
