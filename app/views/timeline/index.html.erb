<main class="tt-page-main">
  <section class="tt-page-section-feed">
    <% timeline_heading = (@active_tab == :similar ? "おすすめタイムライン" : "全体タイムライン") %>
    <h1 class="tt-page-heading-feed"><%= timeline_heading %></h1>

    <%= render "timeline/feed",
               posts: @posts,
               has_next: @has_next,
               next_path: @next_path,
               active_tab: @active_tab,
               empty_state_lines: @empty_state_lines,
               similar_state: @similar_state,
               similar_polling_interval_ms: TimelineController::SIMILAR_POLLING_INTERVAL_MS %>
  </section>
</main>
