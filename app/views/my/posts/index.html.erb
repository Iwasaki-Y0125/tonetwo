<main class="tt-page-main">
  <section class="tt-page-section-feed">
    <h1 class="tt-page-heading-feed">自分の投稿一覧</h1>

    <% if @posts.any? %>
      <div class="tt-surface mt-4 overflow-hidden">
        <%= render "my/posts/post_rows", posts: @posts %>
        <%= render "my/posts/next_frame", has_next: @has_next, next_path: @next_path %>
      </div>
    <% else %>
      <div class="tt-empty-state mt-4">
        投稿はまだありません。
      </div>
    <% end %>
  </section>
</main>
