<aside class="fixed left-[max(1.5rem,calc((100vw-72rem)/2+1.5rem))] top-[120px] z-20 hidden w-52 lg:block">
  <div class="tt-shadow-min rounded-3xl border border-white/70 bg-white/65 p-2 backdrop-blur-sm">
    <div class="rounded-[1.25rem] bg-white/60 p-2">
      <nav class="space-y-1.5 text-base font-semibold">
        <% timeline_active = current_page?(timeline_path) || current_page?(similar_timeline_path) %>
        <%= link_to(timeline_path, class: ["side-nav-link flex items-center gap-3 rounded-xl px-4 py-3 transition", (timeline_active ? "bg-[#68CBCE] !text-[#FFF]" : "bg-transparent text-[#858EA6] hover:bg-[#eef7f8] hover:text-[#3A486D]")]) do %>
          <svg class="<%= ["h-5 w-5", (timeline_active ? "opacity-100" : "opacity-60")].join(" ") %>" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true">
            <path d="M180-140v-450l300-225.77L780-590v450H556.15v-267.69h-152.3V-140H180Z"/>
          </svg>
          <span>ホーム</span>
        <% end %>

        <% my_posts_active = current_page?(my_posts_path) %>
        <%= link_to(my_posts_path, class: ["side-nav-link flex items-center gap-3 rounded-xl px-4 py-3 transition", (my_posts_active ? "bg-[#68CBCE] !text-[#FFF]" : "bg-transparent text-[#858EA6] hover:bg-[#eef7f8] hover:text-[#3A486D]")]) do %>
          <svg class="<%= ["h-5 w-5", (my_posts_active ? "opacity-100" : "opacity-60")].join(" ") %>" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true">
            <path d="M240.92-268.31q51-37.84 111.12-59.77Q412.15-350 480-350t127.96 21.92q60.12 21.93 111.12 59.77 37.3-41 59.11-94.92Q800-417.15 800-480q0-133-93.5-226.5T480-800q-133 0-226.5 93.5T160-480q0 62.85 21.81 116.77 21.81 53.92 59.11 94.92ZM480-450q-54.77 0-92.38-37.62Q350-525.23 350-580q0-54.77 37.62-92.38Q425.23-710 480-710q54.77 0 92.38 37.62Q610-634.77 610-580q0 54.77-37.62 92.38Q534.77-450 480-450Zm0 350q-79.15 0-148.5-29.77t-120.65-81.08q-51.31-51.3-81.08-120.65Q100-400.85 100-480t29.77-148.5q29.77-69.35 81.08-120.65 51.3-51.31 120.65-81.08Q400.85-860 480-860t148.5 29.77q69.35 29.77 120.65 81.08 51.31 51.3 81.08 120.65Q860-559.15 860-480t-29.77 148.5q-29.77 69.35-81.08 120.65-51.3 51.31-120.65 81.08Q559.15-100 480-100Z"/>
          </svg>
          <span>投稿一覧</span>
        <% end %>

        <div class="flex items-center gap-3 rounded-xl px-4 py-3 text-[#858EA6] transition hover:bg-[#eef7f8] hover:text-[#3A486D]">
          <svg class="h-5 w-5 opacity-60" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true">
            <path d="M100-118.46v-669.23Q100-818 121-839q21-21 51.31-21h615.38Q818-860 839-839q21 21 21 51.31v455.38Q860-302 839-281q-21 21-51.31 21H241.54L100-118.46Z"/>
          </svg>
          <span>チャット</span>
        </div>
      </nav>
    </div>
  </div>

  <%= link_to(new_post_path, class: "side-nav-link group mt-16 block w-full !text-[#fff]") do %>
    <span class="relative block">
      <%= image_tag "postbtn.svg", alt: "", class: "tt-postbtn-sticker block w-full h-auto transition" %>
      <span class="pointer-events-none absolute right-10 top-[40%] -translate-y-1/2 -rotate-6 text-base font-semibold tracking-wide !text-[#fff]">投稿する？</span>
    </span>
  <% end %>
</aside>
