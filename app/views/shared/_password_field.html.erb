<% aria_label_text = local_assigns.fetch(:aria_label, "パスワードを表示") %>
<% extra_controllers = local_assigns.fetch(:controllers, "").to_s.strip %>
<% input_data = { password_visibility_target: "input" }.merge(local_assigns.fetch(:input_data, {})) %>
<% controllers = ["password-visibility"] %>
<% controllers << extra_controllers if extra_controllers.present? %>
<% fieldset_data = { controller: controllers.join(" ") }.merge(local_assigns.fetch(:fieldset_data, {})) %>

<%= content_tag :fieldset, class: "fieldset", data: fieldset_data do %>
  <legend class="fieldset-legend text-base font-semibold"><%= legend %></legend>

  <div class="relative">
    <%= form.password_field field_name,
                            required: true,
                            autocomplete: autocomplete,
                            placeholder: placeholder,
                            maxlength: 72,
                            class: "input input-plain w-full bg-white pr-14",
                            data: input_data %>
    <button type="button"
            class="absolute inset-y-0 right-4 my-auto inline-flex h-6 w-6 items-center justify-center z-10"
            aria-label="<%= aria_label_text %>"
            data-password-visibility-target="toggleButton"
            data-action="password-visibility#toggle">
      <%= image_tag "icons/visibility.svg",
                    alt: "パスワードを表示する",
                    class: "h-5 w-5",
                    data: { password_visibility_target: "visibleIcon" } %>
      <%= image_tag "icons/visibility_off.svg",
                    alt: "パスワードを非表示にする",
                    class: "h-5 w-5 hidden",
                    data: { password_visibility_target: "hiddenIcon" } %>
    </button>
  </div>

  <% if block_given? %>
    <%= yield %>
  <% end %>
<% end %>
