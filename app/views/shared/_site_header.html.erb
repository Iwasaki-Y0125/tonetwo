<% if authenticated? %>
  <% timeline_active = current_page?(timeline_path) %>
  <% similar_active = current_page?(similar_timeline_path) %>
  <% my_posts_active = current_page?(my_posts_path) || controller_path == "my/posts" %>
  <% chats_active = current_page?(chats_path) || controller_name == "chats" %>
  <% settings_active = current_page?(settings_path) %>

  <header class="tt-site-header tt-site-header-auth">
    <div class="tt-shell">
      <div class="tt-site-header-grid">
        <%= link_to timeline_path, class: "tt-site-header-logo-link tt-site-header-logo-link-start" do %>
          <%= image_tag "Logo.svg", alt: "ToneTwo", class: "tt-header-logo block h-6 w-auto" %>
        <% end %>

        <nav class="tt-site-header-nav">
          <ul class="tt-header-nav-strip tt-site-header-nav-list">
            <li>
              <%= link_to timeline_path, class: ["tt-header-nav-link", (timeline_active ? "tt-header-nav-link-active" : nil)] do %>
                <%= tt_header_icon("icons/home.svg") %>
                <span class="tt-header-nav-text">全体</span>
              <% end %>
            </li>
            <li>
              <%= link_to similar_timeline_path, class: ["tt-header-nav-link", (similar_active ? "tt-header-nav-link-active" : nil)] do %>
                <%= tt_header_icon("icons/star_shine.svg") %>
                <span class="tt-header-nav-text">おすすめ</span>
              <% end %>
            </li>
            <li>
              <%= link_to chats_path, class: ["tt-header-nav-link", (chats_active ? "tt-header-nav-link-active" : nil)] do %>
                <%= tt_header_icon("icons/chat_bubble.svg") %>
                <span class="tt-header-nav-text">チャット</span>
              <% end %>
            </li>
            <li>
              <%= link_to my_posts_path, class: ["tt-header-nav-link", (my_posts_active ? "tt-header-nav-link-active" : nil)] do %>
                <%= tt_header_icon("icons/account_circle.svg") %>
                <span class="tt-header-nav-text">MY投稿</span>
              <% end %>
            </li>
            <li>
              <%= link_to settings_path, class: ["tt-header-nav-link", (settings_active ? "tt-header-nav-link-active" : nil)] do %>
                <%= tt_header_icon("icons/settings.svg") %>
                <span class="tt-header-nav-text">設定</span>
              <% end %>
            </li>
          </ul>
        </nav>

        <div aria-hidden="true"></div>
      </div>
    </div>
  </header>

  <nav class="tt-mobile-footer-nav md:hidden" aria-label="メインナビゲーション">
    <ul class="tt-mobile-footer-nav-list">
      <li>
        <%= link_to timeline_path, class: ["tt-mobile-footer-nav-link", (timeline_active ? "tt-mobile-footer-nav-link-active" : nil)] do %>
          <%= tt_header_icon("icons/home.svg") %>
          <span class="tt-mobile-footer-nav-label">ホーム</span>
        <% end %>
      </li>
      <li>
        <%= link_to similar_timeline_path, class: ["tt-mobile-footer-nav-link", (similar_active ? "tt-mobile-footer-nav-link-active" : nil)] do %>
          <%= tt_header_icon("icons/star_shine.svg") %>
          <span class="tt-mobile-footer-nav-label">おすすめ</span>
        <% end %>
      </li>
      <li>
        <%= link_to chats_path, class: ["tt-mobile-footer-nav-link", (chats_active ? "tt-mobile-footer-nav-link-active" : nil)] do %>
          <%= tt_header_icon("icons/chat_bubble.svg") %>
          <span class="tt-mobile-footer-nav-label">チャット</span>
        <% end %>
      </li>
      <li>
        <%= link_to my_posts_path, class: ["tt-mobile-footer-nav-link", (my_posts_active ? "tt-mobile-footer-nav-link-active" : nil)] do %>
          <%= tt_header_icon("icons/account_circle.svg") %>
          <span class="tt-mobile-footer-nav-label">MY投稿</span>
        <% end %>
      </li>
      <li>
        <%= link_to settings_path, class: ["tt-mobile-footer-nav-link", (settings_active ? "tt-mobile-footer-nav-link-active" : nil)] do %>
          <%= tt_header_icon("icons/settings.svg") %>
          <span class="tt-mobile-footer-nav-label">設定</span>
        <% end %>
      </li>
    </ul>
  </nav>
<% else %>
  <header class="tt-site-header">
    <div class="tt-shell">
      <div class="tt-site-header-public-row">
        <%= link_to root_path, class: "tt-site-header-logo-link" do %>
          <%= image_tag "Logo.svg", alt: "ToneTwo", class: "tt-header-logo block h-6 w-auto" %>
        <% end %>
        <div class="tt-site-header-public-actions">
          <%= link_to "ユーザー登録", new_sign_up_path, class: "btn btn-primary tt-site-header-action-btn" %>
          <%= link_to "ログイン", new_session_path, class: "btn btn-outline tt-subtle-outline-btn tt-site-header-action-btn" %>
        </div>
      </div>
    </div>
  </header>
<% end %>
