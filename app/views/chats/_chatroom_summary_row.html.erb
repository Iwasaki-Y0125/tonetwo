<% latest_message = chatroom.latest_message %>
<% latest_message_at = chatroom.latest_message_at %>
<%= link_to chat_path(chatroom), class: "block px-5 py-4 transition hover:bg-base-200/60" do %>
  <div class="flex items-start justify-between gap-3">
    <div class="flex min-w-0 items-center gap-2">
      <% if title.present? %>
        <p class="<%= title_class %>"><%= title %></p>
      <% end %>
    </div>
    <p class="shrink-0 text-xs text-base-content/50"><%= tt_datetime_label(latest_message_at&.in_time_zone("Asia/Tokyo")) %></p>
  </div>
  <p class="<%= subtitle_class %>">
    <%= latest_message&.body.to_s.strip.presence || "まだメッセージがありません" %>
  </p>
<% end %>
