<% latest_message = chatroom.latest_message %>
<% latest_message_at = chatroom.latest_message_at %>
<% waiting_for_reply = chatroom.last_sender_id == Current.user.id %>
<% has_unread = !waiting_for_reply && chatroom.has_unread? %>
<% status_label = if waiting_for_reply
                    "返信待ち"
                  elsif has_unread
                    "新着"
                  end %>
<% status_badge_class = if waiting_for_reply
                          "bg-base-content/70 text-base-100"
                        elsif has_unread
                          "bg-info/80 text-info-content"
                        end %>
<% row_class = waiting_for_reply ? "block px-5 py-4 bg-base-300/60 transition hover:bg-base-300/70" : "block px-5 py-4 transition hover:bg-base-200/60" %>

<%= link_to chat_path(chatroom), class: row_class do %>
  <div class="flex items-start justify-between gap-3">
    <div class="flex min-w-0 items-center gap-2">
      <% if title.present? %>
        <p class="<%= title_class %>"><%= title %></p>
      <% end %>
      <% if status_label.present? %>
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold <%= status_badge_class %>">
          <%= status_label %>
        </span>
      <% end %>
    </div>
    <p class="shrink-0 text-xs font-normal text-base-content/50"><%= tt_datetime_label(latest_message_at&.in_time_zone("Asia/Tokyo")) %></p>
  </div>
  <p class="<%= subtitle_class %>">
    <%= latest_message&.body.to_s.strip.presence || "まだメッセージがありません" %>
  </p>
<% end %>
