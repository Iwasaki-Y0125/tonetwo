<main class="tt-page-main">
  <section class="tt-page-section-feed">
    <h1 class="tt-page-heading-feed-plain">チャット</h1>

    <div class="mt-4 rounded-2xl bg-info/20 p-5 md:p-6"
         data-controller="compose-focus"
         data-action="pointerdown->compose-focus#activate click->compose-focus#activate">
      <div class="min-h-[20rem] space-y-2">
        <%= render "chats/seed_post_bubble", post: @chatroom.post, current_user: Current.user %>

        <% @chat_messages.each do |message| %>
          <%= render "chats/message_bubble", message: message, current_user: Current.user %>
        <% end %>
      </div>

      <%= render "chats/composer_form",
                 model: @chat_message,
                 url: chat_messages_path(@chatroom),
                 margin_class: "mt-4" %>
    </div>
  </section>
</main>
