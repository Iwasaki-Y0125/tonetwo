<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tone Two" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="<%= asset_path('favicon.svg') %>" type="image/svg+xml">
    <link rel="icon" href="<%= asset_path('favicon.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon.png') %>">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% hide_site_header = content_for?(:hide_site_header) %>
  <body data-theme="pastel" class="tt-page-bg min-h-screen text-base-content">
    <%= render "shared/site_header" unless hide_site_header %>
    <% if authenticated? %>
      <% show_compose_sidebar = current_page?(timeline_path) || current_page?(similar_timeline_path) %>
      <div class="<%= hide_site_header ? "tt-layout-auth-no-header" : "tt-layout-auth" %>">
        <div class="tt-shell tt-layout-shell">
          <div class="tt-layout-main-column">
            <% if show_compose_sidebar %>
              <div class="tt-layout-compose-anchor">
                <div class="tt-layout-compose-sticky">
                  <%= render "shared/compose_sidebar" %>
                </div>
              </div>
            <% end %>

            <div class="tt-layout-flash-overlay">
              <div class="tt-flash-layer">
                <% if flash[:notice] %>
                <div class="alert alert-success tt-flash-toast tt-layout-flash-toast">
                  <span class="font-semibold text-white"><%= flash[:notice] %></span>
                  <button type="button"
                          class="btn btn-ghost btn-xs text-white hover:text-white/90"
                          aria-label="閉じる"
                          onclick="this.closest('.tt-flash-toast').remove()">
                    ✕
                  </button>
                </div>
                <% end %>
                <% if flash[:alert] %>
                <div class="alert alert-error tt-flash-toast tt-layout-flash-toast">
                  <span class="font-semibold text-white"><%= flash[:alert] %></span>
                  <button type="button"
                          class="btn btn-ghost btn-xs text-white hover:text-white/90"
                          aria-label="閉じる"
                          onclick="this.closest('.tt-flash-toast').remove()">
                    ✕
                  </button>
                </div>
                <% end %>
              </div>
              <% if flash[:notice] || flash[:alert] %>
                <script>
                  setTimeout(() => {
                    document.querySelectorAll(".tt-flash-toast").forEach((el) => el.remove())
                  }, 10000)
                </script>
              <% end %>
            </div>
            <%= yield %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="<%= hide_site_header ? "tt-layout-guest-no-header" : "tt-layout-guest" %>">
        <%= yield %>
      </div>
    <% end %>
    <turbo-frame id="policy_modal"></turbo-frame>
  </body>
</html>
