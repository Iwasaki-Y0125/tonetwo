<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tone Two" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="<%= asset_path('favicon.svg') %>" type="image/svg+xml">
    <link rel="icon" href="<%= asset_path('favicon.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon.png') %>">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-theme="pastel" class="min-h-screen bg-base-200 text-base-content">
    <%= render "shared/site_header" %>
    <% if authenticated? %>
      <div class="pt-16">
        <div class="tt-shell py-8">
          <div class="relative mx-auto w-full max-w-[540px]">
            <div class="absolute left-full top-16 ml-6 hidden w-[300px] lg:block">
              <div class="sticky top-24">
                <%= render "shared/compose_sidebar" %>
              </div>
            </div>

            <div class="pointer-events-none absolute inset-x-0 top-0 z-40">
              <div class="tt-flash-layer">
                <% if flash[:notice] %>
                <div class="alert alert-success tt-flash-toast pointer-events-auto inline-flex w-fit max-w-full text-white">
                  <span class="font-semibold text-white"><%= flash[:notice] %></span>
                  <button type="button"
                          class="btn btn-ghost btn-xs text-white hover:text-white/90"
                          aria-label="閉じる"
                          onclick="this.closest('.tt-flash-toast').remove()">
                    ✕
                  </button>
                </div>
                <% end %>
                <% if flash[:alert] %>
                <div class="alert alert-error tt-flash-toast pointer-events-auto inline-flex w-fit max-w-full text-white">
                  <span class="font-semibold text-white"><%= flash[:alert] %></span>
                  <button type="button"
                          class="btn btn-ghost btn-xs text-white hover:text-white/90"
                          aria-label="閉じる"
                          onclick="this.closest('.tt-flash-toast').remove()">
                    ✕
                  </button>
                </div>
                <% end %>
              </div>
              <% if flash[:notice] || flash[:alert] %>
                <script>
                  setTimeout(() => {
                    document.querySelectorAll(".tt-flash-toast").forEach((el) => el.remove())
                  }, 10000)
                </script>
              <% end %>
            </div>
            <%= yield %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="pt-16">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
