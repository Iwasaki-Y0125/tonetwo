<!DOCTYPE html>
<html>
  <head>
    <title>メンテナンス中 | Tone Two</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="<%= asset_path('favicon.svg') %>" type="image/svg+xml">
    <link rel="icon" href="<%= asset_path('favicon.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon.png') %>">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>
  <body data-theme="pastel" class="tt-page-bg min-h-screen text-base-content">
    <div class="min-h-screen flex items-center justify-center px-6 py-20">
      <div class="w-full max-w-xl rounded-3xl bg-white shadow-xl px-8 py-8 text-center">
        <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-base-200 flex items-center justify-center">
          <%= image_tag "Logo.svg", alt: "ToneTwo", class: "h-8 w-auto" %>
        </div>
        <h1 class="text-2xl font-bold tracking-tight">現在、定期メンテナンス中です。</h1>
        <p class="mt-4 text-base leading-relaxed">
          メンテナンスは4/6 13:30 ~ 15:00を予定しています。
        </p>
        <p class="mt-3 text-sm text-base-content/70">
          終了次第、アクセスできるようになります。時間をおいてお試しください。
        </p>
      </div>
    </div>
  </body>
</html>
