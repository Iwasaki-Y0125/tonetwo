<div class="p-8 max-w-3xl">
  <div class="prose">
    <h1>Root Test Page</h1>
    <p>It works!</p>
  </div>

  <div class="stats shadow mt-6">
    <div class="stat">
      <div class="stat-title">Rails.env</div>
      <div class="stat-value text-primary"><%= Rails.env %></div>
    </div>
    <div class="stat">
      <div class="stat-title">Time</div>
      <div class="stat-value text-secondary"><%= Time.current %></div>
    </div>
  </div>
</div>

<div class="p-8">
  <div class="card bg-base-100 tt-shadow-min max-w-md">
    <div class="card-body">
      <h2 class="card-title">DaisyUI OK</h2>
      <p>Tailwind + DaisyUI が反映されています。</p>

      <div class="divider my-2"></div>

      <% if authenticated? %>
        <p>
          現在ログイン中: はい（<span class="font-semibold"><%= Current.user&.email_address %></span>）
        </p>
      <% else %>
        <p>現在ログイン中: いいえ</p>
      <% end %>

      <div class="card-actions justify-end">
        <% if authenticated? %>
          <%= link_to "新規投稿", new_post_path, class: "btn btn-brand" %>
          <%= link_to "ログアウト", session_path, data: { turbo_method: :delete }, class: "btn btn-outline" %>
        <% else %>
          <%= link_to "ユーザー登録", new_sign_up_path, class: "btn btn-brand" %>
          <%= link_to "ログイン", new_session_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
